{
  "id": "card_catalog",
  "layout_family": "accordion_drawer",
  "metaphor": "card_catalog",
  "visual_language": "warm library reading room — polished oak veneer, brass hardware, typed index card labels, manila folder tabs, cream paper stock, letterpress typography",
  "encounter": "browseable_field",
  "intent": "professional_archive",
  "components": [
    {
      "id": "cabinet_body",
      "role": "container",
      "description": "Tall wooden card catalog cabinet with stacked drawers"
    },
    {
      "id": "drawer",
      "role": "collection_unit",
      "description": "Individual labeled drawer with brass pull and typed index label"
    },
    {
      "id": "drawer_contents",
      "role": "work_reveal",
      "description": "Hanging folder accordion that drops when drawer is opened"
    },
    {
      "id": "folder_tab",
      "role": "work_unit",
      "description": "Clickable folder tab that lays flat to reveal full artwork"
    }
  ],
  "ui_spec": {
    "PORTFOLIO.title": {
      "editable": true,
      "role": "cabinet_nameplate"
    },
    "COLLECTION.title": {
      "editable": true,
      "role": "drawer_label"
    },
    "COLLECTION.works": {
      "editable": true
    },
    "WORK.images": {
      "editable": true
    }
  },
  "layout_engine": {
    "type": "vertical_stack",
    "drawer_default": "closed",
    "open_behavior": "accordion_drop",
    "work_reveal": "folder_click_flat",
    "scroll": "vertical"
  }
}