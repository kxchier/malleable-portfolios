{
  "task": "PORTFOLIO",
  "entities": {
    "PORTFOLIO": {
      "description": "Root task object for an art portfolio presentation",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "title": { "type": "SVAL", "dataType": "string", "function": "publicIdentifier" },
        "artist": { "type": "PNTR", "target": "ARTIST" },
        "collections": { "type": "ARRY", "itemType": "PNTR", "target": "COLLECTION" },
        "arrangements": { "type": "ARRY", "itemType": "PNTR", "target": "SITE_ARRANGEMENT", "optional": true }
      }
    },
    "ARTIST": {
      "description": "The artist whose work is presented",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "name": { "type": "SVAL", "dataType": "string", "function": "publicIdentifier" },
        "bio": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true },
        "links": { "type": "ARRY", "itemType": "SVAL", "optional": true }
      }
    },
    "COLLECTION": {
      "description": "A curated group of works, often mapped from a folder",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "title": { "type": "SVAL", "dataType": "string", "function": "publicIdentifier" },
        "works": { "type": "ARRY", "itemType": "PNTR", "target": "WORK" },
        "presentation_notes": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true }
      }
    },
    "WORK": {
      "description": "A single artwork or page (v1: one image per work)",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "title": { "type": "SVAL", "dataType": "string", "function": "publicIdentifier" },
        "images": { "type": "ARRY", "itemType": "SVAL" },
        "medium": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true },
        "year": { "type": "SVAL", "dataType": "number", "function": "display", "optional": true },
        "description": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true },
        "link": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true },
        "tags": { "type": "ARRY", "itemType": "SVAL", "optional": true },
        "status": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true },
        "visibility": { "type": "SVAL", "dataType": "string", "function": "display", "optional": true }
      }
    },
    "SITE_ARRANGEMENT": {
      "description": "Per-site display curation: ordered display collections that point at existing works",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "presentation": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "collections": { "type": "ARRY", "itemType": "PNTR", "target": "DISPLAY_COLLECTION" }
      }
    },
    "DISPLAY_COLLECTION": {
      "description": "A site-specific collection label and ordered list of existing works",
      "attributes": {
        "id": { "type": "SVAL", "dataType": "string", "function": "privateIdentifier" },
        "title": { "type": "SVAL", "dataType": "string", "function": "publicIdentifier" },
        "works": { "type": "ARRY", "itemType": "PNTR", "target": "WORK" }
      }
    }
  },
  "dependencies": []
}
